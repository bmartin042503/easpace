<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:templatedControls="using:easpace.Styles.TemplatedControls"
        xmlns:converters="using:easpace.Converters"
        xmlns:generic="clr-namespace:System.Collections.Generic;assembly=System.Collections"
        xmlns:controls="clr-namespace:easpace.Controls"
        xmlns:services="clr-namespace:easpace.Services">
    <Design.PreviewWith>
        <!-- To change between Dark/Light mode in the Preview, change the RequestedThemeVariant value -->
        <ThemeVariantScope RequestedThemeVariant="Light">
            <Border Padding="20" Background="{DynamicResource Neutral100}">

                <StackPanel Orientation="Vertical" Spacing="20">

                    <!-- Sample MoodEntry item 1 - with description, labels -->
                    <templatedControls:MoodEntry
                        Description="Woke up feeling incredibly refreshed and ready to tackle the day."
                        MoodSliderValue="0.9"
                        Date="2026-02-22T22:25:00">
                        <templatedControls:MoodEntry.Labels>
                            <generic:List x:TypeArguments="x:String">
                                <x:String>Energetic</x:String>
                                <x:String>Rested</x:String>
                            </generic:List>
                        </templatedControls:MoodEntry.Labels>
                    </templatedControls:MoodEntry>

                    <!-- Sample MoodEntry item 2 - with description, labels -->
                    <templatedControls:MoodEntry
                        Description="A bit stressed about the upcoming deadline, but managing."
                        MoodSliderValue="0.4"
                        Date="2026-02-22T22:10:00">
                        <templatedControls:MoodEntry.Labels>
                            <generic:List x:TypeArguments="x:String">
                                <x:String>Anxious</x:String>
                                <x:String>Focused</x:String>
                            </generic:List>
                        </templatedControls:MoodEntry.Labels>
                    </templatedControls:MoodEntry>

                    <!-- Sample MoodEntry item 3 - with description -->
                    <templatedControls:MoodEntry
                        Description="Had a really nice meal with an old friend."
                        MoodSliderValue="0.8"
                        Date="2026-02-22T18:00:00" />

                    <!-- Sample MoodEntry item 4 -->
                    <templatedControls:MoodEntry
                        MoodSliderValue="0.5"
                        Date="2026-02-21T10:00:00" />

                    <!-- Sample MoodEntry item 5 - with labels -->
                    <templatedControls:MoodEntry
                        MoodSliderValue="0.7"
                        Date="2026-02-18T14:30:00">
                        <templatedControls:MoodEntry.Labels>
                            <generic:List x:TypeArguments="x:String">
                                <x:String>Peaceful</x:String>
                                <x:String>Nature</x:String>
                            </generic:List>
                        </templatedControls:MoodEntry.Labels>
                    </templatedControls:MoodEntry>

                    <!-- Sample MoodEntry item 6 - with description -->
                    <templatedControls:MoodEntry
                        Description="Just feeling really tired today, nothing specific happened."
                        MoodSliderValue="0.2"
                        Date="2026-02-01T09:00:00" />

                    <!-- Sample MoodEntry item 7 - with labels -->
                    <templatedControls:MoodEntry
                        MoodSliderValue="0.6"
                        Date="2025-12-10T11:00:00">
                        <templatedControls:MoodEntry.Labels>
                            <generic:List x:TypeArguments="x:String">
                                <x:String>Okay</x:String>
                                <x:String>Routine</x:String>
                            </generic:List>
                        </templatedControls:MoodEntry.Labels>
                    </templatedControls:MoodEntry>

                    <!-- Sample MoodEntry item 8 -->
                    <templatedControls:MoodEntry
                        MoodSliderValue="1.0"
                        Date="2025-08-05T16:20:00" />

                    <!-- Sample MoodEntry item 9 -->
                    <templatedControls:MoodEntry
                        MoodSliderValue="0.1"
                        Date="2025-01-15T08:00:00" />

                    <!-- Sample MoodEntry item 10 - with description, labels -->
                    <templatedControls:MoodEntry
                        Description="Watched a great comedy, laughed a lot."
                        MoodSliderValue="0.85"
                        Date="2023-11-20T20:00:00">
                        <templatedControls:MoodEntry.Labels>
                            <generic:List x:TypeArguments="x:String">
                                <x:String>Happy</x:String>
                                <x:String>Amused</x:String>
                                <x:String>Relaxed</x:String>
                            </generic:List>
                        </templatedControls:MoodEntry.Labels>
                    </templatedControls:MoodEntry>

                </StackPanel>
            </Border>
        </ThemeVariantScope>
    </Design.PreviewWith>

    <!-- MoodEntry template -->
    <Style Selector="templatedControls|MoodEntry">
        <Style.Resources>
            <converters:MoodSliderValueConverter x:Key="MoodSliderValueConverter" />
            <converters:DateTimeConverter x:Key="DateTimeConverter" />
        </Style.Resources>

        <Setter Property="Template">
            <ControlTemplate>
                <Border Classes="secondaryCard" Padding="20">

                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto,Auto">

                        <!-- Mood text -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   x:Name="MoodTextBlock"
                                   Text="{Binding 
                                        Path=MoodSliderValue, 
                                        Converter={StaticResource MoodSliderValueConverter}, 
                                        RelativeSource={RelativeSource TemplatedParent}}" />

                        <!-- Context menu button (dots) -->
                        <Button Grid.Row="0" Grid.Column="1"
                                Classes="moodEntryContextButton">
                            
                            <Viewbox Width="20" Height="20">
                                <Path Data="{StaticResource DotsThreeIcon}"/>
                            </Viewbox>
                            
                            <Button.Flyout>
                                <controls:MoodEntryFlyout>
                                    <Border Classes="primaryCard" Padding="0" CornerRadius="6">
                                        <Button
                                            Classes="contextMenuButton"
                                            Content="{services:LocalizationService Key='DELETE'}"/>
                                    </Border>
                                </controls:MoodEntryFlyout>
                            </Button.Flyout>
                            
                        </Button>

                        <!-- Relative date time -->
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   x:Name="MoodDateTextBlock"
                                   Text="{Binding 
                                Path=Date, 
                                Converter={StaticResource DateTimeConverter}, 
                                RelativeSource={RelativeSource TemplatedParent}}" />

                        <!-- Description -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                   x:Name="MoodDescriptionTextBlock"
                                   Margin="0,20,0,0"
                                   Text="{TemplateBinding Description}"
                                   IsVisible="{TemplateBinding Description,
                                        Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <!-- Labels -->
                        <ItemsControl x:Name="LabelsItemsControl"
                                      Grid.Row="3"
                                      Grid.Column="0"
                                      Margin="0,20,0,0"
                                      ItemsSource="{TemplateBinding Labels}">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" ItemSpacing="10" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.DataTemplates>
                                <DataTemplate x:DataType="x:String">

                                    <!-- Label item -->
                                    <Border Classes="primaryCard">
                                        <TextBlock x:Name="LabelTextBlock" Text="{Binding .}" />
                                    </Border>

                                </DataTemplate>
                            </ItemsControl.DataTemplates>
                        </ItemsControl>
                    </Grid>

                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- MoodEntry styling -->
    <Style Selector="templatedControls|MoodEntry">
        <Style Selector="^ /template/ TextBlock#MoodTextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource Neutral700}" />
        </Style>

        <Style Selector="^ /template/ TextBlock#MoodDateTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Neutral400}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="^ /template/ TextBlock#MoodDescriptionTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Neutral700}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style Selector="^ TextBlock#LabelTextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Neutral700}" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Medium" />
        </Style>

        <!-- Label card (border) styles -->
        <Style Selector="^ Border.primaryCard">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <!-- set ItemsControls visibility if its empty or null to avoid use of unnecessary margins -->
        <Style Selector="^ /template/ ItemsControl#LabelsItemsControl[ItemCount=0]">
            <Setter Property="IsVisible" Value="False" />
        </Style>

        <Style Selector="^ /template/ ItemsControl#LabelsItemsControl[ItemsSource={x:Null}]">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </Style>
</Styles>
