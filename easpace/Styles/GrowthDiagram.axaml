    <Style Selector="controls|GrowthDiagram">
        <Setter Property="AxisLineBrush" Value="{DynamicResource Neutral500}" />
        <Setter Property="LineThickness" Value="4" />
        <Setter Property="DataLineBrush" Value="{DynamicResource Primary600}" />
        <Setter Property="Padding" Value="48" />
        <Setter Property="Ticks" Value="3"/>
        <Setter Property="TickWidth" Value="14"/>
    </Style>
</Styles>
