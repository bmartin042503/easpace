                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="88.8"
                                                      Date="2019-04-01T07:50:00" />
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="87.6"
                                                      Date="2019-10-10T15:30:00" />
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="86.7"
                                                      Date="2020-01-20T08:15:00" />
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="85.4"
                                                      Date="2020-07-04T12:00:00" />
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="85.5"
