                                                      Date="2016-05-05T06:00:00" />
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="92.3"
                                                      Date="2016-08-19T08:10:00" />
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="90.5"
                                                      Date="2017-03-22T07:45:00" />
