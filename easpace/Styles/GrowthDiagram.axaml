                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="83.3"
                                                      Date="2022-02-14T07:30:00" />
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="82.0"
                                                      Date="2022-10-31T07:45:00" />
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="81.2"
                                                      Date="2023-09-18T19:20:00" />
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="80.0"
                                                      Date="2024-01-01T09:00:00" />
