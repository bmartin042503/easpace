<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:easpace.Controls"
        xmlns:models="clr-namespace:easpace.Models"
        xmlns:generic="clr-namespace:System.Collections.Generic;assembly=System.Collections"
        xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Design.PreviewWith>
        <!-- To change between Dark/Light mode in the Preview, change the RequestedThemeVariant value -->
        <ThemeVariantScope RequestedThemeVariant="Light">
            <Border Padding="20" Background="{DynamicResource Neutral100}" Height="400" Width="800">
                <controls:GrowthDiagram>
                    <controls:GrowthDiagram.Entries>
                        <generic:List x:TypeArguments="models:IGrowthTargetEntry">
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="98.0"
                                                      Date="2015-01-05T06:30:00" />
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="95.2"
                                                      Date="2015-05-12T08:00:00" />
                            <models:GrowthTargetEntry x:TypeArguments="sys:Double" Value="96.1"
                                                      Date="2015-09-10T11:40:00" />
