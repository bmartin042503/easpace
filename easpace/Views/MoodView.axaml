<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:easpace.ViewModels"
             xmlns:models="clr-namespace:easpace.Models"
             xmlns:services="clr-namespace:easpace.Services"
             xmlns:templatedControls="clr-namespace:easpace.Styles.TemplatedControls"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="easpace.Views.MoodView"
             x:DataType="vm:MoodViewModel"
             Background="{DynamicResource Neutral100}">

    <Grid RowDefinitions="Auto,Auto,*" ColumnDefinitions="3*,*,3*,Auto" Margin="26">

        <!-- Main title -->
        <TextBlock Grid.Column="0" Grid.Row="0"
                   Text="{services:LocalizationService Key='MOOD_TITLE'}"
                   Classes="pageTitle" />

        <!-- Subtitle -->
        <TextBlock Grid.Column="0" Grid.Row="1"
                   Text="{services:LocalizationService Key='MOOD_SUBTITLE'}"
                   Classes="pageSubTitle" />

        <!-- Mood entries -->
        <ScrollViewer Grid.Row="2" Grid.Column="0" Margin="0,20,0,0">
            <ItemsControl ItemsSource="{Binding MoodEntries}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" Spacing="16" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.DataTemplates>
                    <DataTemplate DataType="models:MoodEntry">

                        <!-- Build of a single mood entry item -->
                        <templatedControls:MoodEntry
                            MoodSliderValue="{Binding MoodSliderValue}"
                            Date="{Binding Date}"
                            Description="{Binding Description}"
                            Labels="{Binding Labels}" />

                    </DataTemplate>
                </ItemsControl.DataTemplates>
            </ItemsControl>
        </ScrollViewer>

        <!-- New mood entry -->
        <StackPanel Grid.Row="2" Grid.Column="2" Spacing="40" VerticalAlignment="Center">

            <!-- Mood entry title -->
            <TextBlock Classes="newMoodEntryTitle" Text="{services:LocalizationService Key='NEW_MOOD_ENTRY_TITLE'}" />

            <StackPanel Orientation="Vertical">

                <!-- Mood state -->
                <TextBlock Classes="moodStateText" Text="{Binding MoodStateText}" />

                <!-- Mood slider -->
                <Slider Classes="moodSlider" Minimum="0" Maximum="1" MaxWidth="250" Value="{Binding MoodSliderValue}"/>

            </StackPanel>

            <Border Classes="secondaryCard" Padding="20">
                <StackPanel Orientation="Vertical" Spacing="20">

                    <!-- TODO: fix scrollviewer height sizing to be responsive -->
                    <!-- Mood label items -->
                    <ScrollViewer MaxHeight="140">
                        <ItemsControl ItemsSource="{Binding MoodLabels}">

                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" ItemSpacing="12" LineSpacing="12"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.DataTemplates>
                                <DataTemplate DataType="models:MoodLabel">

                                    <!-- Build of a single mood label item -->
                                    <ToggleButton IsChecked="{Binding IsChecked}"
                                                  Classes="moodLabelToggleButton">
                                        <TextBlock Text="{Binding Name}" />
                                    </ToggleButton>

                                </DataTemplate>
                            </ItemsControl.DataTemplates>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBox
                        Height="75"
                        AcceptsReturn="True"
                        Watermark="{services:LocalizationService Key='OTHER'}"
                        Classes="largeTextBox" />
                    
                    <Button Classes="saveButton" HorizontalAlignment="Center">
                        <TextBlock Text="{services:LocalizationService Key='SAVE'}" />
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>

    </Grid>
</UserControl>
