<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:templatedControls="using:easpace.Desktop.Styles.TemplatedControls">
    <Design.PreviewWith>
        <!-- To change between Dark/Light mode in the Preview, change the RequestedThemeVariant value -->
        <ThemeVariantScope RequestedThemeVariant="Light">
            <Border Padding="20" Background="{DynamicResource Neutral100}">
                <StackPanel Orientation="Vertical" Spacing="12">
                    
                    <!-- Sample JournalEntry item 1 -->
                    <templatedControls:JournalEntry Title="Journal Entry 1"/>
                    
                    <!-- Sample JournalEntry item 2 -->
                    <templatedControls:JournalEntry Title="Journal Entry 2"/>
                    
                    <!-- Sample JournalEntry item 3 -->
                    <templatedControls:JournalEntry Title="Journal Entry 3"/>
                    
                    <!-- Sample JournalEntry item 4 - selected -->
                    <templatedControls:JournalEntry Title="Journal Entry 4" Classes="selected"/>
                    
                    <!-- Sample JournalEntry item 5 -->
                    <templatedControls:JournalEntry Title="Journal Entry 5"/>
                </StackPanel>
            </Border>
        </ThemeVariantScope>
    </Design.PreviewWith>

    <!-- JournalEntry template -->
    <Style Selector="templatedControls|JournalEntry">
        <Setter Property="Template">
            <ControlTemplate>
                <Button Content="{TemplateBinding Title}"
                        Command="{TemplateBinding SelectCommand}"
                        CommandParameter="{Binding DataContext, RelativeSource={RelativeSource TemplatedParent}}"/>
            </ControlTemplate>
        </Setter>
    </Style>
    
    <!-- JournalEntry styling -->
    <Style Selector="templatedControls|JournalEntry">
        <Style Selector="^ /template/ Button">
            <Setter Property="Padding" Value="0"/>
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource Neutral600}" />
            </Style>

            <Style Selector="^:pressed /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent" />
            </Style>

            <Setter Property="Foreground" Value="{DynamicResource Neutral600}" />
        </Style>
        
        <Style Selector="^.selected /template/ Button">
            <Setter Property="Foreground" Value="{DynamicResource Primary600}" />
            <Style Selector="^:pointerover /template/ ContentPresenter">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource Primary600}" />
            </Style>
        </Style>
    </Style>
</Styles>
